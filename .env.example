# Copy this file to .env and fill in your values
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/digital_store
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
UPLOAD_PATH=./uploads
BTC_WALLET=YOUR_BTC_ADDRESS_HERE
USDT_WALLET=YOUR_USDT_TRC20_ADDRESS_HERE
ADMIN_EMAIL=admin@yourdomain.com

# ── OxaPay ────────────────────────────────────────────────────────
OXAPAY_MERCHANT_KEY=YOUR_OXAPAY_MERCHANT_KEY
OXAPAY_CALLBACK_URL=https://yourdomain.com/api/deposits/oxapay/webhook
OXAPAY_RETURN_URL=https://yourdomain.com/deposit.html

# ── Production only ───────────────────────────────────────────────
# NODE_ENV=production
# ALLOWED_ORIGINS=https://yourdomain.com

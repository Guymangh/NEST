# Copy this file to .env and fill in your values
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/digital_store
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
UPLOAD_PATH=./uploads
BTC_WALLET=YOUR_BTC_ADDRESS_HERE
USDT_WALLET=YOUR_USDT_TRC20_ADDRESS_HERE
ADMIN_EMAIL=admin@yourdomain.com

# ── NowPayments ───────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=YOUR_NOWPAYMENTS_API_KEY
NOWPAYMENTS_PUBLIC_KEY=YOUR_NOWPAYMENTS_PUBLIC_KEY
NOWPAYMENTS_IPN_SECRET=YOUR_NOWPAYMENTS_IPN_SECRET
NOWPAYMENTS_CALLBACK_URL=https://yourdomain.com/api/deposits/nowpayments/webhook
NOWPAYMENTS_SUCCESS_URL=https://yourdomain.com/deposit.html
NOWPAYMENTS_CANCEL_URL=https://yourdomain.com/deposit.html

# ── Production only ───────────────────────────────────────────────
# NODE_ENV=production
# ALLOWED_ORIGINS=https://yourdomain.com
